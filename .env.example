# Set to "true" to use mock data instead of live contract calls
NEXT_PUBLIC_USE_MOCKS=true

# Soroban RPC endpoint (Testnet default shown)
# For mainnet, use the server-side proxy (see MAINNET_RPC_URL below)
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Server-side RPC URLs (never exposed to browser)
# Mainnet RPC with API key (server-side only, kept secret)
MAINNET_RPC_URL=
# Testnet RPC (server-side, optional - defaults to public endpoint)
TESTNET_RPC_URL=https://soroban-testnet.stellar.org

# Stellar network (testnet | mainnet)
NEXT_PUBLIC_STELLAR_NETWORK=testnet

# Deployed ProofOfHeart contract address (C…)
NEXT_PUBLIC_CONTRACT_ADDRESS=

# Stellar network passphrase
# Testnet: "Test SDF Network ; September 2015"
# Mainnet: "Public Global Stellar Network ; September 2015"
NEXT_PUBLIC_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Optional webhook to receive creator email opt-in events (off-chain only)
NEXT_PUBLIC_CREATOR_EMAIL_WEBHOOK_URL=

# Soroban campaign_vote_cast event poll interval on detail page (ms, default 5000)
NEXT_PUBLIC_VOTE_EVENTS_POLL_MS=5000

# Vote tally reconciliation when event streaming unavailable (ms, default 30000)
NEXT_PUBLIC_VOTE_TALLIES_POLL_MS=30000

# Estimated Soroban network fee (stroops) shown in DonationModal before signing (default 100000 = 0.01 XLM)
# NEXT_PUBLIC_ESTIMATED_CONTRIBUTE_NETWORK_FEE_STROOPS=100000

# Optional webhook for structured observability events (Datadog, Splunk, etc.)
NEXT_PUBLIC_OBSERVABILITY_WEBHOOK_URL=

# Maintenance mode — set to "true" to show the maintenance page to all visitors
# NEXT_PUBLIC_MAINTENANCE_MODE=false
# Comma-separated Stellar wallet addresses that bypass the maintenance page
# NEXT_PUBLIC_MAINTENANCE_ALLOWLIST=GXXX...admin1,GXXX...admin2
# Human-readable ETA shown on the maintenance page (optional)
# NEXT_PUBLIC_MAINTENANCE_ETA=2026-06-02 18:00 UTC

# Alert thresholds (0–1 rates) evaluated over a 5-minute rolling window
OBSERVABILITY_ALERT_SIMULATION_FAILURE_RATE=0.15
OBSERVABILITY_ALERT_SUBMISSION_FAILURE_RATE=0.1
OBSERVABILITY_ALERT_RPC_TIMEOUT_RATE=0.2
